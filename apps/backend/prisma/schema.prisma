// learn more about it in the docs: https://pris.ly/d/prisma-schema

// apps/backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

model Tenant {
  id                   String                 @id @default(cuid())
  name                 String
  phoneNumber          String
  logoUrl              String? // For white-labeling 
  colorScheme          String? // For white-labeling 
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  hasProduct           Boolean                @default(false)
  hasSale              Boolean                @default(false)
  hasInvitedUser       Boolean                @default(false)
  onboardingCompletedAt DateTime?             // null = not completed; set when owner reaches first value
  users                User[]
  customers    Customer[]
  creditSales  CreditSale[]
  products             Product[]
  sales                Sale[]
  Shifts               Shift[]
  categories           Category[]
  inventoryLogs        InventoryLog[]
  storeSettings        StoreSettings?
  loginHistory         LoginHistory[]
  auditLogs            AuditLog[]
  idempotencyKeys      IdempotencyKey[]
  syncChanges          SyncChange[]
  globalCatalogContributions GlobalProductCatalog[] @relation("TenantGlobalCatalog")
  // Stripe support removed
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  phoneNumber         String               @unique
  name                String?
  phoneVerified       Boolean              @default(false)
  phoneVerifiedAt     DateTime?
  role                UserRole             @default(CASHIER) // Roles include Owner, Manager, Cashier 
  isActive            Boolean              @default(true) // Account active/inactive status
  failedLoginAttempts Int                  @default(0) // Count of failed login attempts
  lockedUntil         DateTime? // Account locked until this time (auto-unlock after 15 min)
  lastLoginAt         DateTime? // Timestamp of last successful login
  isFirstLogin        Boolean              @default(true) // Cleared to false after first successful login
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  shifts              Shift[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  otpTokens           OtpToken[]
  loginHistory        LoginHistory[]
  auditLogs           AuditLog[]
  tenantId            String?
  tenant              Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  setupToken          String?              @unique
  setupTokenExpires   DateTime?
  idempotencyKeys     IdempotencyKey[]
  status              String?

  @@index([tenantId])
  @@index([lockedUntil])
}

model Product {
  id                 String   @id @default(cuid())
  productName        String   @default("products")
  productImage       String   @default("string")
  productColor       String   @default("yellow")
  productDescription String   @default("helooo")
  costPrice          Decimal  @default(0.0)
  sellingPrice       Decimal  @default(0.0)
  quantity           Int      @default(0)
  stock              Int      @default(0)
  createdAt          DateTime @default(now())
  barcode            String?  @unique
  sku                String?
  updatedAt          DateTime @updatedAt
  version            Int      @default(0)
  deleted            Boolean  @default(false)
  deletedAt          DateTime?

  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems     SaleItem[]
  inventoryLogs InventoryLog[]

  categoryId String? // Optional, a product might not have a category
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull) // If category is deleted, set this field to null

  globalCatalogId String? // Optional: Link to global product catalog
  globalCatalog   GlobalProductCatalog? @relation(fields: [globalCatalogId], references: [id], onDelete: SetNull)

  @@unique([sku, tenantId])
  @@index([productName])
  @@index([tenantId])
  @@index([categoryId])
  @@index([globalCatalogId])
}

model Sale {
  id              String           @id @default(cuid())
  totalAmount     Decimal
  paymentMethod   String
  taxRate         Decimal          @default(0.0) // e.g., 0.075 for 7.5%
  taxAmount       Decimal          @default(0.0) // calculated: subtotal * taxRate
  subtotal        Decimal          @default(0.0) // before tax
  customerName    String?          // Name of customer — used for credit sales and receipts
  saleNote        String?          // Optional cashier note about this sale
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           SaleItem[]
  userId          String?
  creditSale      CreditSale?
  inventoryLogs   InventoryLog[]
  shiftId         String?
  shift           Shift?           @relation(fields: [shiftId], references: [id])
  version         Int      @default(0)
  deleted            Boolean  @default(false)
  idempotencyKeys IdempotencyKey[]

  @@index([shiftId])
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model Customer {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  phone       String?
  totalOwed   Decimal      @default(0.0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  creditSales CreditSale[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model CreditSale {
  id          String    @id @default(cuid())
  tenantId    String
  customerId  String
  saleId      String    @unique
  amount      Decimal
  amountPaid  Decimal   @default(0.0)
  balance     Decimal
  settled     Boolean   @default(false)
  settledAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  customer    Customer  @relation(fields: [customerId], references: [id])
  sale        Sale      @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, settled])
}

model IdempotencyKey {
  key       String   @id
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  saleId    String?
  sale      Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  status    String   @default("PENDING")
  response  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
}

model SaleItem {
  id       String  @id @default(cuid())
  quantity Int
  price    Decimal

  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  updatedAt DateTime @updatedAt

  @@index([saleId])
}

model Category {
  id           String     @id @default(cuid())
  categoryName String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  version      Int        @default(0)
  deleted      Boolean    @default(false)
  deletedAt    DateTime?
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId     String? // Optional: A category can be a top-level one
  parent       Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction)
  children     Category[] @relation("CategoryHierarchy")
  products     Product[]

  @@index([tenantId])
  @@index([parentId])
}

model InventoryLog {
  id            String   @id @default(cuid())
  change        Int // The amount the stock changed by (e.g., -2 or +50)
  newStockLevel Int // The stock level of the product *after* the change
  reason        String // e.g., "SALE", "STOCK_IN", "RETURN", "DAMAGE"
  notes         String? // Optional notes for manual adjustments
  createdAt     DateTime @default(now())

  // Relations
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Optional link to the sale that triggered this log
  saleId    String?
  sale      Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  updatedAt DateTime @updatedAt
  version   Int      @default(0)

  @@index([tenantId])
  @@index([productId])
  @@index([saleId])
}

model GlobalProductCatalog {
  id                      String   @id @default(cuid())
  barcode                 String   @unique // Primary identifier for products
  productName             String   @db.VarChar(255)
  description             String?  @db.Text // Detailed product description
  imageUrl                String?  // URL to product image
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  version                 Int      @default(0) // For tracking updates
  
  // Track which tenant contributed this product
  contributedByTenantId   String?
  contributedByTenant     Tenant?  @relation("TenantGlobalCatalog", fields: [contributedByTenantId], references: [id], onDelete: SetNull)
  
  // Products that reference this global catalog entry
  products                Product[]

  @@index([barcode])
  @@index([productName])
  @@index([contributedByTenantId])
}

model SyncChange {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  version    Int
  operation  String
  data       Json
  deleted    Boolean  @default(false)
  timestamp  DateTime @default(now())

  @@index([tenantId, entityType, timestamp])
  @@index([tenantId, entityType, entityId, version])
}

// Transaction and Refund models removed (Stripe support removed)

model StoreSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  storeName           String
  storeAddress        String?
  storePhone          String?
  storeTaxId          String?
  operatingHoursStart String? // e.g., "09:00"
  operatingHoursEnd   String? // e.g., "18:00"
  businessType        String? // e.g., "retail", "f&b", "pharmacy"
  currency            String   @default("NGN")
  language            String   @default("en")
  dateFormat          String   @default("MM/DD/YYYY")
  timeFormat          String   @default("HH:mm")
  numberFormat        String   @default("en-US") // locale
  logoUrl             String?
  receiptHeader       String?
  receiptFooter       String?
  theme               String   @default("light") // "light" or "dark"
  offlineModeEnabled  Boolean  @default(true)
  autoSyncInterval    Int      @default(300) // seconds
  vatEnabled          Boolean  @default(false) // VAT is OFF by default. Most Nigerian SMEs are not VAT-registered.
  vatRate             Decimal  @default(0.0)   // e.g. 0.075 for 7.5%. Only applied when vatEnabled is true.
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}


model Shift {
  id             String    @id @default(cuid())
  tenantId       String // Mandatory for multi-tenancy
  cashierId      String // The user who clocked in
  startTime      DateTime  @default(now())
  endTime        DateTime? // Nullable: indicates an active shift
  startFloat     Decimal   @default(0.00) // Starting cash amount (float)
  endFloat       Decimal? // Closing cash count (for manager reconciliation)
  reconciliation Json? // Stores reconciliation details (variance, manager notes, etc.)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  cashier        User      @relation(fields: [cashierId], references: [id])
  sales          Sale[] // All sales made during this shift

  @@index([tenantId])
  @@index([cashierId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // SHA256 hash of the refresh token
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // SHA256 hash of the reset token
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model OtpToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber String
  codeHash    String // SHA256 hash of numeric OTP code
  expiresAt   DateTime
  used        Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([phoneNumber])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  success   Boolean // true for successful login, false for failed attempts
  reason    String? // Failure reason: "INVALID_CREDENTIALS", "ACCOUNT_LOCKED", "ACCOUNT_INACTIVE", etc.
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action       String // e.g., "CREATE_USER", "UPDATE_PRODUCT", "DELETE_SALE", "CHANGE_PASSWORD"
  resourceType String // e.g., "User", "Product", "Sale"
  resourceId   String? // ID of the affected resource
  changes      Json? // JSON object of field changes: { old: {...}, new: {...} }
  description  String?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}





enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
  CREDIT
}
