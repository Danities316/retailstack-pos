# ========================================
# Notification Services Configuration
# ========================================

# Email Service: Resend
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=

# Sender email address for all notifications
MAIL_FROM=noreply@retailstack.com

# ========================================
# SMS Service Configuration
# ========================================

# SMS Provider: 'mock' (default, for testing) or 'kudis' (KudiSMS for production)
SMS_PROVIDER=mock

# KudiSMS Configuration (only needed if SMS_PROVIDER=kudis)
# Get from: https://my.kudisms.net/dashboard
KUDISMS_API_KEY=
KUDISMS_SENDER_ID=RETAILSTACK
APP_NAME_CODE=
TEMPLATE_CODE=

# ========================================
# Application URLs
# ========================================

# Base URL for the application (used in email links)
# Development: http://localhost:5173
# Production: https://retailstack.com
BASE_URL=http://localhost:5173

# ========================================
# Database
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/retailstack

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET=your-super-secret-key-min-32-chars-random

# ========================================
# Environment
# ========================================
NODE_ENV=development
DEBUG=false
