# ========================================
# RetailStack POS - Frontend Configuration
# ========================================

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT_MS=30000

# Offline-First Configuration
VITE_OFFLINE_ENABLED=true
VITE_AUTO_SYNC_ENABLED=true
VITE_SYNC_INTERVAL_MS=30000

# Service Worker
VITE_SERVICE_WORKER_ENABLED=true

# Feature Flags
VITE_FEATURE_MANUAL_CONFLICT_RESOLUTION=true
VITE_FEATURE_SHOW_CONFLICT_INDICATORS=true
VITE_FEATURE_SHOW_DEBUG_INFO=false

# Database
VITE_INDEXEDDB_ENABLED=true
VITE_DB_VERSION=1

# UI Configuration
VITE_SHOW_SYNC_STATUS=true
VITE_SHOW_PENDING_MUTATIONS=true

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_SENTRY_DSN=

# Build
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=RetailStack POS
